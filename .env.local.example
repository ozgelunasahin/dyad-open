# Local Supabase development environment
#
# Setup:
#   1. Install Docker and Supabase CLI (npx supabase)
#   2. Run: npm run setup
#   3. Copy this file to .env.local: cp .env.local.example .env.local
#   4. Paste keys from `npx supabase status` output below
#
# Test users (created by seed.sql):
#   digit@test.local / local-fixture-not-a-secret  (primary user, admin)
#   other@test.local / local-fixture-not-a-secret  (secondary user)

PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
PUBLIC_SUPABASE_ANON_KEY=<paste anon key from: npx supabase status>
SUPABASE_SERVICE_ROLE_KEY=<paste service_role key from: npx supabase status>
