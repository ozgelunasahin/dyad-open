      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Hold" bpmnElement="Flow_Hold">
        <di:waypoint x="920" y="275" />
        <di:waypoint x="920" y="360" />
        <di:waypoint x="1020" y="360" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="930" y="333" width="24" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_HoldEnd" bpmnElement="Flow_HoldEnd">
        <di:waypoint x="1120" y="360" />
        <di:waypoint x="1172" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Accepted" bpmnElement="Flow_Accepted">
        <di:waypoint x="945" y="250" />
        <di:waypoint x="1020" y="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="955" y="233" width="46" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_V6" bpmnElement="Flow_V6">
        <di:waypoint x="1120" y="250" />
        <di:waypoint x="1170" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_V7" bpmnElement="Flow_V7">
        <di:waypoint x="1270" y="250" />
        <di:waypoint x="1320" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_V8" bpmnElement="Flow_V8">
        <di:waypoint x="1420" y="250" />
        <di:waypoint x="1470" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_V9" bpmnElement="Flow_V9">
        <di:waypoint x="1570" y="250" />
        <di:waypoint x="1620" y="250" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_V10" bpmnElement="Flow_V10">
        <di:waypoint x="1720" y="250" />
        <di:waypoint x="1772" y="250" />
