<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1">
  <bpmn:collaboration id="Collaboration_MeetingFeedback">
    <bpmn:participant id="Pool_Tom" name="Tom" processRef="Process_Tom" />
    <bpmn:participant id="Pool_Sophie" name="Sophie" processRef="Process_Sophie" />
    <bpmn:participant id="Pool_System" name="System" processRef="Process_System" />
    <bpmn:messageFlow id="MsgFlow_Tom_CalendarAdd" name="Calendar add" sourceRef="Task_Tom_AddCalendar" targetRef="Task_Sys_GenerateCalendarLink" />
    <bpmn:messageFlow id="MsgFlow_Tom_Cancellation" name="Cancellation" sourceRef="Task_Tom_Explanation" targetRef="Task_Sys_HandleCancellation" />
    <bpmn:messageFlow id="MsgFlow_Tom_CancelLate" name="Late cancel / no-show" sourceRef="Task_Tom_ReputationMark" targetRef="Task_Sys_HandleCancellation" />
    <bpmn:messageFlow id="MsgFlow_Tom_Feedback" name="Tom&#39;s feedback" sourceRef="Task_Tom_SubmitFeedback" targetRef="Task_Sys_ReceiveHoldFeedback" />
    <bpmn:messageFlow id="MsgFlow_Sophie_Feedback" name="Sophie&#39;s feedback" sourceRef="Task_Sophie_SubmitFeedback" targetRef="Task_Sys_ReceiveHoldFeedback" />
    <bpmn:messageFlow id="MsgFlow_Sys_Tom_Details" name="Meeting details" sourceRef="Task_Sys_DisplayDetails" targetRef="Task_Tom_ViewDetails" />
    <bpmn:messageFlow id="MsgFlow_Sys_Tom_FeedbackReveal" name="Feedback reveal" sourceRef="Task_Sys_RevealFeedback" targetRef="ICE_Tom_BothSubmitted" />
    <bpmn:messageFlow id="MsgFlow_Sys_Sophie_FeedbackReveal" name="Feedback reveal" sourceRef="Task_Sys_RevealFeedback" targetRef="ICE_Sophie_BothSubmitted" />
    <bpmn:textAnnotation id="Annot_CancelEarly">
      <bpmn:text>Requires free-text explanation (at least, once meeting is scheduled). Explanation logged for moderation pattern detection.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annot_CancelLate">
      <bpmn:text>maybe 1 free pass before reputation mark becomes visible on profile. Not a blacklist but visible signals. repeated cancels/no-shows trigger moderation</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annot_FeedbackForm">
      <bpmn:text>Full form: Did it take place? (if no, why?) / How was it? / What do you think of [person] as conversation partner? / Select adjectives (admin-curated vocabulary) + free text / What to share with the other person / What to share with the platform / Any comments for the platform</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annot_AppGating">
      <bpmn:text>Explore/map view and creating/responding to new conversations are gated. Users can still manage existing invitations (confirm/cancel meetings)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annot_TimerActivation">
      <bpmn:text>Activates at meeting START time, not end. Feedback can be given immediately (no-show after 15 min, short meeting, etc).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annot_ModeratorMinimal">
      <bpmn:text>Community is self-moderating through structure. Moderator intervention should be minimised.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annot_SimultaneousReveal">
      <bpmn:text>Simultaneous reveal prevents retaliation bias. Neither party sees feedback until both have submitted.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1n6p7k9">
      <bpmn:text>≥12h: cancel + reactivate; &lt;12h: reputation mark)</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SimultaneousReveal" associationDirection="None" sourceRef="Task_Sys_RevealFeedback" targetRef="Annot_SimultaneousReveal" />
    <bpmn:association id="Assoc_ModeratorMinimal" associationDirection="None" sourceRef="Task_Sys_ModeratorIntervention" targetRef="Annot_ModeratorMinimal" />
    <bpmn:association id="Association_1sf331o" associationDirection="None" sourceRef="Task_Sys_HandleCancellation" targetRef="TextAnnotation_1n6p7k9" />
    <bpmn:association id="Assoc_CancelEarly" associationDirection="None" sourceRef="GW_Tom_Cancel" targetRef="Annot_CancelEarly" />
    <bpmn:association id="Assoc_CancelLate" associationDirection="None" sourceRef="End_Tom_CancelLate" targetRef="Annot_CancelLate" />
    <bpmn:association id="Assoc_TimerActivation" associationDirection="None" sourceRef="Timer_Tom_NextLogin" targetRef="Annot_TimerActivation" />
    <bpmn:association id="Assoc_FeedbackForm" associationDirection="None" sourceRef="Task_Tom_FillFeedback" targetRef="Annot_FeedbackForm" />
    <bpmn:association id="Assoc_AppGating" associationDirection="None" sourceRef="Task_Tom_AppGated" targetRef="Annot_AppGating" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Tom" isExecutable="false">
    <bpmn:task id="Task_Tom_MeetingCancelled" name="Meeting cancelled, conversation reappears">
      <bpmn:incoming>Flow_Tom_CancelEarly2</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_CancelEarlyEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Tom_CancelEarly" name="Cancelled (no penalty)">
      <bpmn:incoming>Flow_Tom_CancelEarlyEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:startEvent id="Start_Tom" name="Receives confirmation">
      <bpmn:outgoing>Flow_Tom_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Tom_ViewDetails" name="Views scheduled meeting details (exact location)">
      <bpmn:incoming>Flow_Tom_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ViewCancelPolicy" name="Views cancellation policy (12h window)">
      <bpmn:incoming>Flow_Tom_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_AddCalendar" name="(Optional) Adds to calendar">
      <bpmn:incoming>Flow_Tom_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Tom_Cancel" name="Cancel?">
      <bpmn:incoming>Flow_Tom_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_CancelEarly</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tom_CancelLate</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tom_NoCancel</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Tom_ShowUp" name="Shows up at agreed time and place">
      <bpmn:incoming>Flow_Tom_NoCancel</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_MeetsSophie" name="Meets Sophie, has conversation">
      <bpmn:incoming>Flow_Tom_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ReputationMark" name="Reputation mark applied">
      <bpmn:incoming>Flow_Tom_CancelLate</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_CancelLateEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Tom_CancelLate" name="Cancelled (reputation mark)">
      <bpmn:incoming>Flow_Tom_CancelLateEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Tom_PartsWays" name="Conversation ends, parts ways">
      <bpmn:incoming>Flow_Tom_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Timer_Tom_NextLogin" name="Next login after meeting start time">
      <bpmn:incoming>Flow_Tom_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_8</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Tom" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Tom_AppGated" name="Explore/new conversations gated: must give feedback">
      <bpmn:incoming>Flow_Tom_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_FillFeedback" name="Fills out feedback form">
      <bpmn:incoming>Flow_Tom_9</bpmn:incoming>
      <bpmn:incoming>Flow_Tom_EditYes</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Tom_EditFeedback" name="Edit feedback? (editable until both submit)">
      <bpmn:incoming>Flow_Tom_11</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_EditYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tom_EditNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Tom_SubmitFeedback" name="Submits feedback">
      <bpmn:incoming>Flow_Tom_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ViewFeedback" name="Views Sophie&#39;s feedback">
      <bpmn:incoming>Flow_Tom_13</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="IWait_Tom" name="Waits for Sophie&#39;s feedback">
      <bpmn:incoming>Flow_Tom_EditNo</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_12</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Tom_Wait" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="ICE_Tom_BothSubmitted" name="Both feedbacks submitted">
      <bpmn:incoming>Flow_Tom_12</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_13</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Tom_BothSubmitted" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Tom_ChooseProfile" name="Chooses whether to show feedback on profile">
      <bpmn:incoming>Flow_Tom_14</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Tom" name="Feedback complete, app unlocked">
      <bpmn:incoming>Flow_Tom_15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Tom_Explanation" name="Provides explanation">
      <bpmn:incoming>Flow_Tom_CancelEarly</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_CancelEarly2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Tom_CancelEarly2" sourceRef="Task_Tom_Explanation" targetRef="Task_Tom_MeetingCancelled" />
    <bpmn:sequenceFlow id="Flow_Tom_CancelEarlyEnd" sourceRef="Task_Tom_MeetingCancelled" targetRef="End_Tom_CancelEarly" />
    <bpmn:sequenceFlow id="Flow_Tom_1" sourceRef="Start_Tom" targetRef="Task_Tom_ViewDetails" />
    <bpmn:sequenceFlow id="Flow_Tom_2" sourceRef="Task_Tom_ViewDetails" targetRef="Task_Tom_ViewCancelPolicy" />
    <bpmn:sequenceFlow id="Flow_Tom_3" sourceRef="Task_Tom_ViewCancelPolicy" targetRef="Task_Tom_AddCalendar" />
    <bpmn:sequenceFlow id="Flow_Tom_4" sourceRef="Task_Tom_AddCalendar" targetRef="GW_Tom_Cancel" />
    <bpmn:sequenceFlow id="Flow_Tom_CancelEarly" name="Cancel ≥12h before" sourceRef="GW_Tom_Cancel" targetRef="Task_Tom_Explanation" />
    <bpmn:sequenceFlow id="Flow_Tom_CancelLate" name="Cancel &#60;12h / no-show" sourceRef="GW_Tom_Cancel" targetRef="Task_Tom_ReputationMark" />
    <bpmn:sequenceFlow id="Flow_Tom_NoCancel" name="No" sourceRef="GW_Tom_Cancel" targetRef="Task_Tom_ShowUp" />
    <bpmn:sequenceFlow id="Flow_Tom_5" sourceRef="Task_Tom_ShowUp" targetRef="Task_Tom_MeetsSophie" />
    <bpmn:sequenceFlow id="Flow_Tom_6" sourceRef="Task_Tom_MeetsSophie" targetRef="Task_Tom_PartsWays" />
    <bpmn:sequenceFlow id="Flow_Tom_CancelLateEnd" sourceRef="Task_Tom_ReputationMark" targetRef="End_Tom_CancelLate" />
    <bpmn:sequenceFlow id="Flow_Tom_7" sourceRef="Task_Tom_PartsWays" targetRef="Timer_Tom_NextLogin" />
    <bpmn:sequenceFlow id="Flow_Tom_8" sourceRef="Timer_Tom_NextLogin" targetRef="Task_Tom_AppGated" />
    <bpmn:sequenceFlow id="Flow_Tom_9" sourceRef="Task_Tom_AppGated" targetRef="Task_Tom_FillFeedback" />
    <bpmn:sequenceFlow id="Flow_Tom_EditYes" name="Yes (edit)" sourceRef="GW_Tom_EditFeedback" targetRef="Task_Tom_FillFeedback" />
    <bpmn:sequenceFlow id="Flow_Tom_10" sourceRef="Task_Tom_FillFeedback" targetRef="Task_Tom_SubmitFeedback" />
    <bpmn:sequenceFlow id="Flow_Tom_11" sourceRef="Task_Tom_SubmitFeedback" targetRef="GW_Tom_EditFeedback" />
    <bpmn:sequenceFlow id="Flow_Tom_EditNo" name="No (done)" sourceRef="GW_Tom_EditFeedback" targetRef="IWait_Tom" />
    <bpmn:sequenceFlow id="Flow_Tom_13" sourceRef="ICE_Tom_BothSubmitted" targetRef="Task_Tom_ViewFeedback" />
    <bpmn:sequenceFlow id="Flow_Tom_14" sourceRef="Task_Tom_ViewFeedback" targetRef="Task_Tom_ChooseProfile" />
    <bpmn:sequenceFlow id="Flow_Tom_12" sourceRef="IWait_Tom" targetRef="ICE_Tom_BothSubmitted" />
    <bpmn:sequenceFlow id="Flow_Tom_15" sourceRef="Task_Tom_ChooseProfile" targetRef="End_Tom" />
  </bpmn:process>
  <bpmn:process id="Process_Sophie" isExecutable="false">
    <bpmn:startEvent id="Start_Sophie" name="Post-meeting">
      <bpmn:outgoing>Flow_Sophie_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:intermediateCatchEvent id="Timer_Sophie_NextLogin" name="Next login after meeting start time">
      <bpmn:incoming>Flow_Sophie_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_2</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Sophie" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Sophie_AppGated" name="Explore/new conversations gated: must give feedback">
      <bpmn:incoming>Flow_Sophie_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_FillFeedback" name="Fills out feedback form (about Tom)">
      <bpmn:incoming>Flow_Sophie_3</bpmn:incoming>
      <bpmn:incoming>Flow_Sophie_EditYes</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_SubmitFeedback" name="Submits feedback">
      <bpmn:incoming>Flow_Sophie_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Sophie_EditFeedback" name="Edit feedback? (editable until both submit)">
      <bpmn:incoming>Flow_Sophie_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_EditYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sophie_EditNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:intermediateCatchEvent id="IWait_Sophie" name="Waits for Tom&#39;s feedback">
      <bpmn:incoming>Flow_Sophie_EditNo</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_6</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Sophie_Wait" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="ICE_Sophie_BothSubmitted" name="Both feedbacks submitted">
      <bpmn:incoming>Flow_Sophie_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_7</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Sophie_BothSubmitted" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Sophie_ViewFeedback" name="Views Tom&#39;s feedback">
      <bpmn:incoming>Flow_Sophie_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_ChooseProfile" name="Chooses whether to show feedback on profile">
      <bpmn:incoming>Flow_Sophie_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Sophie" name="Feedback complete, app unlocked">
      <bpmn:incoming>Flow_Sophie_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Sophie_1" sourceRef="Start_Sophie" targetRef="Timer_Sophie_NextLogin" />
    <bpmn:sequenceFlow id="Flow_Sophie_2" sourceRef="Timer_Sophie_NextLogin" targetRef="Task_Sophie_AppGated" />
    <bpmn:sequenceFlow id="Flow_Sophie_3" sourceRef="Task_Sophie_AppGated" targetRef="Task_Sophie_FillFeedback" />
    <bpmn:sequenceFlow id="Flow_Sophie_EditYes" name="Yes (edit)" sourceRef="GW_Sophie_EditFeedback" targetRef="Task_Sophie_FillFeedback" />
    <bpmn:sequenceFlow id="Flow_Sophie_4" sourceRef="Task_Sophie_FillFeedback" targetRef="Task_Sophie_SubmitFeedback" />
    <bpmn:sequenceFlow id="Flow_Sophie_5" sourceRef="Task_Sophie_SubmitFeedback" targetRef="GW_Sophie_EditFeedback" />
    <bpmn:sequenceFlow id="Flow_Sophie_EditNo" name="No (done)" sourceRef="GW_Sophie_EditFeedback" targetRef="IWait_Sophie" />
    <bpmn:sequenceFlow id="Flow_Sophie_6" sourceRef="IWait_Sophie" targetRef="ICE_Sophie_BothSubmitted" />
    <bpmn:sequenceFlow id="Flow_Sophie_7" sourceRef="ICE_Sophie_BothSubmitted" targetRef="Task_Sophie_ViewFeedback" />
    <bpmn:sequenceFlow id="Flow_Sophie_8" sourceRef="Task_Sophie_ViewFeedback" targetRef="Task_Sophie_ChooseProfile" />
    <bpmn:sequenceFlow id="Flow_Sophie_9" sourceRef="Task_Sophie_ChooseProfile" targetRef="End_Sophie" />
  </bpmn:process>
  <bpmn:process id="Process_System" isExecutable="false">
    <bpmn:startEvent id="Start_System" name="Meeting confirmed">
      <bpmn:outgoing>Flow_Sys_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Sys_DisplayDetails" name="Displays meeting details + cancellation policy">
      <bpmn:incoming>Flow_Sys_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_ToWait</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="Timer_Sys_GateApps" name="Meeting start time reached">
      <bpmn:incoming>Flow_Sys_ToTimerCatch</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_5</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_Sys" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Sys_PresentFeedbackForm" name="Presents feedback form, gates both apps">
      <bpmn:incoming>Flow_Sys_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Sys_BothSubmitted" name="Both submitted?">
      <bpmn:incoming>Flow_Sys_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_NotBoth</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sys_YesBoth</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Sys_RevealFeedback" name="Simultaneously reveals feedback">
      <bpmn:incoming>Flow_Sys_YesBoth</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_RoutePlatformFeedback" name="Routes platform feedback to admin">
      <bpmn:incoming>Flow_Sys_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_UpdateProfiles" name="Updates profiles">
      <bpmn:incoming>Flow_Sys_9</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_UnlockApp" name="Unlocks app for both users">
      <bpmn:incoming>Flow_Sys_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_End</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_System" name="Process complete">
      <bpmn:incoming>Flow_Sys_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Sys_ReceiveHoldFeedback" name="Receives and holds each party&#39;s feedback">
      <bpmn:incoming>Flow_Sys_ToReceive</bpmn:incoming>
      <bpmn:incoming>Flow_Sys_NotBoth</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_ModeratorIntervention" name="Moderator intervention (can ungate waiting party)">
      <bpmn:incoming>Flow_Sys_ToModeratorIntervention</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_ModeratorDone</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Sys_ModeratorUngate" name="Moderator ungated">
      <bpmn:incoming>Flow_Sys_ModeratorDone</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:exclusiveGateway id="GW_Sys_MergeToFeedback" name="Merge">
      <bpmn:incoming>Flow_Sys_MeetingHappened</bpmn:incoming>
      <bpmn:incoming>Flow_Sys_NoShowToFeedback</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_ToReceive</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:exclusiveGateway id="GW_Sys_DidItTakePlace" name="Did the meeting take place?">
      <bpmn:incoming>Flow_Sys_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_NoShow</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sys_MeetingHappened</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Sys_CaptureReason" name="Captures no-show reason">
      <bpmn:incoming>Flow_Sys_NoShow</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_NoShow2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_RouteModerator" name="Routes no-show report to moderator">
      <bpmn:incoming>Flow_Sys_NoShow2</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_NoShowToFeedback</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Sys_Cancel" name="Meeting cancelled">
      <bpmn:incoming>Flow_Sys_CancelEnd</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Sys_LogExplanation" name="Logs explanation for moderation patterns">
      <bpmn:incoming>Flow_Sys_CancelToLog</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_CancelEnd</bpmn:outgoing>
    </bpmn:task>
    <bpmn:intermediateCatchEvent id="ICE_Sys_CancelReceived" name="Cancellation received">
      <bpmn:incoming>Flow_Sys_ToCancelCatch</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_CancelToHandle</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Sys_Cancel" />
    </bpmn:intermediateCatchEvent>
    <bpmn:eventBasedGateway id="GW_Sys_WaitForEvent" name="Await cancellation or meeting time">
      <bpmn:incoming>Flow_Sys_ToWait</bpmn:incoming>
      <bpmn:incoming>Flow_Sys_CalDone</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_ToCancelCatch</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sys_ToTimerCatch</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:task id="Task_Sys_GenerateCalendarLink" name="Generates calendar event link">
      <bpmn:outgoing>Flow_Sys_CalDone</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_HandleCancellation" name="Handles cancellation">
      <bpmn:incoming>Flow_Sys_CancelToHandle</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_CancelToLog</bpmn:outgoing>
    </bpmn:task>
    <bpmn:boundaryEvent id="BoundaryTimer_NeverSubmits" name="Submission timeout" cancelActivity="false" attachedToRef="Task_Sys_ReceiveHoldFeedback">
      <bpmn:outgoing>Flow_Sys_ToModeratorIntervention</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_NeverSubmits" />
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_Sys_1" sourceRef="Start_System" targetRef="Task_Sys_DisplayDetails" />
    <bpmn:sequenceFlow id="Flow_Sys_ToWait" sourceRef="Task_Sys_DisplayDetails" targetRef="GW_Sys_WaitForEvent" />
    <bpmn:sequenceFlow id="Flow_Sys_ToTimerCatch" sourceRef="GW_Sys_WaitForEvent" targetRef="Timer_Sys_GateApps" />
    <bpmn:sequenceFlow id="Flow_Sys_5" sourceRef="Timer_Sys_GateApps" targetRef="Task_Sys_PresentFeedbackForm" />
    <bpmn:sequenceFlow id="Flow_Sys_6" sourceRef="Task_Sys_PresentFeedbackForm" targetRef="GW_Sys_DidItTakePlace" />
    <bpmn:sequenceFlow id="Flow_Sys_7" sourceRef="Task_Sys_ReceiveHoldFeedback" targetRef="GW_Sys_BothSubmitted" />
    <bpmn:sequenceFlow id="Flow_Sys_NotBoth" name="No" sourceRef="GW_Sys_BothSubmitted" targetRef="Task_Sys_ReceiveHoldFeedback" />
    <bpmn:sequenceFlow id="Flow_Sys_YesBoth" name="Yes" sourceRef="GW_Sys_BothSubmitted" targetRef="Task_Sys_RevealFeedback" />
    <bpmn:sequenceFlow id="Flow_Sys_8" sourceRef="Task_Sys_RevealFeedback" targetRef="Task_Sys_RoutePlatformFeedback" />
    <bpmn:sequenceFlow id="Flow_Sys_9" sourceRef="Task_Sys_RoutePlatformFeedback" targetRef="Task_Sys_UpdateProfiles" />
    <bpmn:sequenceFlow id="Flow_Sys_10" sourceRef="Task_Sys_UpdateProfiles" targetRef="Task_Sys_UnlockApp" />
    <bpmn:sequenceFlow id="Flow_Sys_End" sourceRef="Task_Sys_UnlockApp" targetRef="End_System" />
    <bpmn:sequenceFlow id="Flow_Sys_ToReceive" sourceRef="GW_Sys_MergeToFeedback" targetRef="Task_Sys_ReceiveHoldFeedback" />
    <bpmn:sequenceFlow id="Flow_Sys_ToModeratorIntervention" sourceRef="BoundaryTimer_NeverSubmits" targetRef="Task_Sys_ModeratorIntervention" />
    <bpmn:sequenceFlow id="Flow_Sys_ModeratorDone" sourceRef="Task_Sys_ModeratorIntervention" targetRef="End_Sys_ModeratorUngate" />
    <bpmn:sequenceFlow id="Flow_Sys_MeetingHappened" name="Yes" sourceRef="GW_Sys_DidItTakePlace" targetRef="GW_Sys_MergeToFeedback" />
    <bpmn:sequenceFlow id="Flow_Sys_NoShowToFeedback" sourceRef="Task_Sys_RouteModerator" targetRef="GW_Sys_MergeToFeedback" />
    <bpmn:sequenceFlow id="Flow_Sys_NoShow" name="No (no-show)" sourceRef="GW_Sys_DidItTakePlace" targetRef="Task_Sys_CaptureReason" />
    <bpmn:sequenceFlow id="Flow_Sys_NoShow2" sourceRef="Task_Sys_CaptureReason" targetRef="Task_Sys_RouteModerator" />
    <bpmn:sequenceFlow id="Flow_Sys_CancelEnd" sourceRef="Task_Sys_LogExplanation" targetRef="End_Sys_Cancel" />
    <bpmn:sequenceFlow id="Flow_Sys_CancelToLog" sourceRef="Task_Sys_HandleCancellation" targetRef="Task_Sys_LogExplanation" />
    <bpmn:sequenceFlow id="Flow_Sys_ToCancelCatch" sourceRef="GW_Sys_WaitForEvent" targetRef="ICE_Sys_CancelReceived" />
    <bpmn:sequenceFlow id="Flow_Sys_CancelToHandle" sourceRef="ICE_Sys_CancelReceived" targetRef="Task_Sys_HandleCancellation" />
    <bpmn:sequenceFlow id="Flow_Sys_CalDone" sourceRef="Task_Sys_GenerateCalendarLink" targetRef="GW_Sys_WaitForEvent" />
  </bpmn:process>
