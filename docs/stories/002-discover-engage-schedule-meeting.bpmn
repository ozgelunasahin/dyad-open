<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:modeler="http://camunda.org/schema/modeler/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.13.1" modeler:executionPlatform="Camunda Cloud" modeler:executionPlatformVersion="8.0.0">
  <bpmn:collaboration id="Collaboration_DiscoverEngageSchedule">
    <bpmn:participant id="Pool_Tom" name="Tom (Inviter)" processRef="Process_Tom" />
    <bpmn:participant id="Pool_Sophie" name="Sophie (Conversation Starter)" processRef="Process_Sophie" />
    <bpmn:participant id="Pool_System" name="System" processRef="Process_System" />
    <bpmn:messageFlow id="MsgFlow_TomLogin" name="Login request" sourceRef="Task_Tom_ClicksLogin" targetRef="Task_Sys_RendersLogin" />
    <bpmn:messageFlow id="MsgFlow_TomComment" name="Comment submission" sourceRef="Task_Tom_WritesComment" targetRef="Task_Sys_AcceptsComment" />
    <bpmn:messageFlow id="MsgFlow_TomInvite" name="Invite request" sourceRef="Task_Tom_ClicksInvite" targetRef="Task_Sys_CreatesPendingInvite" />
    <bpmn:messageFlow id="MsgFlow_SysNotifySophie" name="Invitation notification" sourceRef="Task_Sys_NotifiesSophie" targetRef="Start_Sophie" />
    <bpmn:messageFlow id="MsgFlow_SophieConfirms" name="Confirmation" sourceRef="Task_Sophie_Confirms" targetRef="IntCatch_Sys_SophieConfirm" />
    <bpmn:messageFlow id="MsgFlow_SysNotifyTom" name="Confirmation + exact location" sourceRef="Task_Sys_NotifiesTom" targetRef="IntCatch_Tom_SophieConfirmed" />
    <bpmn:messageFlow id="MsgFlow_TomCancels" name="Cancellation request" sourceRef="Task_Tom_Cancels" targetRef="Task_Sys_HandlesCancellation" />
    <bpmn:messageFlow id="MsgFlow_SysCalendarTom" name="Calendar event link" sourceRef="Task_Sys_GeneratesCalendar" targetRef="Task_Tom_AddCalendar" />
    <bpmn:textAnnotation id="Annotation_Comment">
      <bpmn:text>Private single-shot message to conversation creator. Other commenters' messages are not visible to Tom.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Comment" sourceRef="Task_Tom_WritesComment" targetRef="Annotation_Comment" />
    <bpmn:textAnnotation id="Annotation_SlotSelection">
      <bpmn:text>No negotiation. Tom picks one option. If Sophie accepts, that's the meeting.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SlotSelection" sourceRef="Task_Tom_SelectsSlot" targetRef="Annotation_SlotSelection" />
    <bpmn:textAnnotation id="Annotation_SophieNotifications">
      <bpmn:text>Sophie can see all comments+invites on her conversation and choose between them.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_SophieNotifications" sourceRef="Task_Sophie_SeesNotifications" targetRef="Annotation_SophieNotifications" />
    <bpmn:textAnnotation id="Annotation_PendingInvitations">
      <bpmn:text>Other pending invitations remain unanswered until 12h cutoff, then treated as not accepted. Revisit based on user experience.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_PendingInvitations" sourceRef="End_Sophie_Confirmed" targetRef="Annotation_PendingInvitations" />
    <bpmn:textAnnotation id="Annotation_RemovesConversation">
      <bpmn:text>Conversation removed from discover/map once meeting scheduled. Reappears if cancelled within cancellation window (≥12h before).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="Annotation_GeneralArea">
      <bpmn:text>General area shown (Airbnb-style, system-generated from exact location). Exact location revealed only after confirmation.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_GeneralArea" sourceRef="Task_Tom_ViewsContent" targetRef="Annotation_GeneralArea" />
    <bpmn:association id="Assoc_RemovesConversation" sourceRef="Task_Sys_RemovesConversation" targetRef="Annotation_RemovesConversation" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Tom" isExecutable="false">
    <bpmn:startEvent id="Start_Tom" name="Arrives on site">
      <bpmn:outgoing>Flow_Tom_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Tom_ClicksLogin" name="Clicks login button">
      <bpmn:incoming>Flow_Tom_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_Authenticates" name="Authenticates">
      <bpmn:incoming>Flow_Tom_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_LandsDiscover" name="Lands on discover page">
      <bpmn:incoming>Flow_Tom_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_Explores" name="Explores what&#39;s there">
      <bpmn:incoming>Flow_Tom_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ExploresMap" name="Explores map view">
      <bpmn:incoming>Flow_Tom_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Tom_Engaging" name="Finds something engaging?">
      <bpmn:incoming>Flow_Tom_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_No</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tom_Yes</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Tom_LogsOff" name="Logs off">
      <bpmn:incoming>Flow_Tom_No</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_EndNo</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Tom_LogsOff" name="End (nothing found)">
      <bpmn:incoming>Flow_Tom_EndNo</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Tom_ClicksConversation" name="Clicks into a conversation">
      <bpmn:incoming>Flow_Tom_Yes</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ViewsContent" name="Views conversation content + general area">
      <bpmn:incoming>Flow_Tom_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_WritesComment" name="Writes a comment (private to Sophie)">
      <bpmn:incoming>Flow_Tom_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_InviteOption" name="Gets option to invite to meet">
      <bpmn:incoming>Flow_Tom_9</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_10</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ViewsSlots" name="Views available time slots with general area">
      <bpmn:incoming>Flow_Tom_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_SelectsSlot" name="Selects ONE time+place option">
      <bpmn:incoming>Flow_Tom_11</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_WritesMessage" name="Writes personal message to Sophie">
      <bpmn:incoming>Flow_Tom_12</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Tom_ClicksInvite" name="Clicks invite">
      <bpmn:incoming>Flow_Tom_13</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:eventBasedGateway id="GW_Tom_EventBased" name="Awaiting response">
      <bpmn:incoming>Flow_Tom_14</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_ToConfirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_Tom_ToCancel</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="IntCatch_Tom_SophieConfirmed" name="Sophie confirmed">
      <bpmn:incoming>Flow_Tom_ToConfirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_16</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_TomConfirmed" messageRef="Message_Confirmation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="IntCatch_Tom_CancelSignal" name="Tom decides to cancel">
      <bpmn:incoming>Flow_Tom_ToCancel</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_CancelToTask</bpmn:outgoing>
      <bpmn:signalEventDefinition id="SignalDef_TomCancel" signalRef="Signal_TomCancels" />
    </bpmn:intermediateCatchEvent>
    <bpmn:task id="Task_Tom_Cancels" name="Cancels invitation">
      <bpmn:incoming>Flow_Tom_CancelToTask</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_EndCancel</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_Tom_Cancelled" name="End (cancelled)">
      <bpmn:incoming>Flow_Tom_EndCancel</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Tom_1" sourceRef="Start_Tom" targetRef="Task_Tom_ClicksLogin" />
    <bpmn:sequenceFlow id="Flow_Tom_2" sourceRef="Task_Tom_ClicksLogin" targetRef="Task_Tom_Authenticates" />
    <bpmn:sequenceFlow id="Flow_Tom_3" sourceRef="Task_Tom_Authenticates" targetRef="Task_Tom_LandsDiscover" />
    <bpmn:sequenceFlow id="Flow_Tom_4" sourceRef="Task_Tom_LandsDiscover" targetRef="Task_Tom_Explores" />
    <bpmn:sequenceFlow id="Flow_Tom_5" sourceRef="Task_Tom_Explores" targetRef="Task_Tom_ExploresMap" />
    <bpmn:sequenceFlow id="Flow_Tom_6" sourceRef="Task_Tom_ExploresMap" targetRef="GW_Tom_Engaging" />
    <bpmn:sequenceFlow id="Flow_Tom_No" name="No" sourceRef="GW_Tom_Engaging" targetRef="Task_Tom_LogsOff" />
    <bpmn:sequenceFlow id="Flow_Tom_Yes" name="Yes" sourceRef="GW_Tom_Engaging" targetRef="Task_Tom_ClicksConversation" />
    <bpmn:sequenceFlow id="Flow_Tom_EndNo" sourceRef="Task_Tom_LogsOff" targetRef="End_Tom_LogsOff" />
    <bpmn:sequenceFlow id="Flow_Tom_7" sourceRef="Task_Tom_ClicksConversation" targetRef="Task_Tom_ViewsContent" />
    <bpmn:sequenceFlow id="Flow_Tom_8" sourceRef="Task_Tom_ViewsContent" targetRef="Task_Tom_WritesComment" />
    <bpmn:sequenceFlow id="Flow_Tom_9" sourceRef="Task_Tom_WritesComment" targetRef="Task_Tom_InviteOption" />
    <bpmn:sequenceFlow id="Flow_Tom_10" sourceRef="Task_Tom_InviteOption" targetRef="Task_Tom_ViewsSlots" />
    <bpmn:sequenceFlow id="Flow_Tom_11" sourceRef="Task_Tom_ViewsSlots" targetRef="Task_Tom_SelectsSlot" />
    <bpmn:sequenceFlow id="Flow_Tom_12" sourceRef="Task_Tom_SelectsSlot" targetRef="Task_Tom_WritesMessage" />
    <bpmn:sequenceFlow id="Flow_Tom_13" sourceRef="Task_Tom_WritesMessage" targetRef="Task_Tom_ClicksInvite" />
    <bpmn:sequenceFlow id="Flow_Tom_14" sourceRef="Task_Tom_ClicksInvite" targetRef="GW_Tom_EventBased" />
    <bpmn:sequenceFlow id="Flow_Tom_ToConfirm" sourceRef="GW_Tom_EventBased" targetRef="IntCatch_Tom_SophieConfirmed" />
    <bpmn:sequenceFlow id="Flow_Tom_ToCancel" sourceRef="GW_Tom_EventBased" targetRef="IntCatch_Tom_CancelSignal" />
    <bpmn:sequenceFlow id="Flow_Tom_CancelToTask" sourceRef="IntCatch_Tom_CancelSignal" targetRef="Task_Tom_Cancels" />
    <bpmn:sequenceFlow id="Flow_Tom_EndCancel" sourceRef="Task_Tom_Cancels" targetRef="End_Tom_Cancelled" />
    <bpmn:sequenceFlow id="Flow_Tom_16" sourceRef="IntCatch_Tom_SophieConfirmed" targetRef="Task_Tom_ViewsMeeting" />
    <bpmn:sequenceFlow id="Flow_Tom_17" sourceRef="Task_Tom_ViewsMeeting" targetRef="Task_Tom_AddCalendar" />
    <bpmn:endEvent id="End_Tom_Scheduled" name="Meeting scheduled">
      <bpmn:incoming>Flow_Tom_18</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Tom_AddCalendar" name="Option to add to calendar">
      <bpmn:incoming>Flow_Tom_17</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_18</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Tom_18" sourceRef="Task_Tom_AddCalendar" targetRef="End_Tom_Scheduled" />
    <bpmn:task id="Task_Tom_ViewsMeeting" name="Views scheduled meeting details (exact location revealed)">
      <bpmn:incoming>Flow_Tom_16</bpmn:incoming>
      <bpmn:outgoing>Flow_Tom_17</bpmn:outgoing>
    </bpmn:task>
  </bpmn:process>
  <bpmn:process id="Process_Sophie" isExecutable="false">
    <bpmn:startEvent id="Start_Sophie" name="Logs in">
      <bpmn:outgoing>Flow_Sophie_1</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_SophieStart" messageRef="Message_InviteNotification" />
    </bpmn:startEvent>
    <bpmn:task id="Task_Sophie_SeesNotifications" name="Sees invitation notifications">
      <bpmn:incoming>Flow_Sophie_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_ClicksInvitation" name="Clicks an invitation">
      <bpmn:incoming>Flow_Sophie_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_ReadsComment" name="Reads Tom&#39;s comment and selected time+place">
      <bpmn:incoming>Flow_Sophie_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Sophie_ReviewProfile" name="Review Tom&#39;s profile?">
      <bpmn:incoming>Flow_Sophie_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_ReviewYes</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sophie_ReviewNo</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Sophie_ViewsProfile" name="Views Tom&#39;s profile">
      <bpmn:incoming>Flow_Sophie_ReviewYes</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_SeesConversations" name="Sees Tom&#39;s conversations">
      <bpmn:incoming>Flow_Sophie_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sophie_SeesTestimonials" name="Sees feedback/testimonials about Tom">
      <bpmn:incoming>Flow_Sophie_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Sophie_ReviewMerge" name="">
      <bpmn:incoming>Flow_Sophie_7</bpmn:incoming>
      <bpmn:incoming>Flow_Sophie_ReviewNo</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_ToReturn</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:task id="Task_Sophie_ReturnsToInvitation" name="Returns to invitation">
      <bpmn:incoming>Flow_Sophie_ToReturn</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:exclusiveGateway id="GW_Sophie_Accept" name="Accept?">
      <bpmn:incoming>Flow_Sophie_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_NotNow</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sophie_Accept</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="End_Sophie_NotNow" name="End (not now)">
      <bpmn:incoming>Flow_Sophie_NotNow</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_Sophie_Confirmed" name="Confirmation sent">
      <bpmn:incoming>Flow_Sophie_9</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Sophie_Confirms" name="Confirms the meeting">
      <bpmn:incoming>Flow_Sophie_Accept</bpmn:incoming>
      <bpmn:outgoing>Flow_Sophie_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Sophie_1" sourceRef="Start_Sophie" targetRef="Task_Sophie_SeesNotifications" />
    <bpmn:sequenceFlow id="Flow_Sophie_2" sourceRef="Task_Sophie_SeesNotifications" targetRef="Task_Sophie_ClicksInvitation" />
    <bpmn:sequenceFlow id="Flow_Sophie_3" sourceRef="Task_Sophie_ClicksInvitation" targetRef="Task_Sophie_ReadsComment" />
    <bpmn:sequenceFlow id="Flow_Sophie_4" sourceRef="Task_Sophie_ReadsComment" targetRef="GW_Sophie_ReviewProfile" />
    <bpmn:sequenceFlow id="Flow_Sophie_ReviewYes" name="Yes" sourceRef="GW_Sophie_ReviewProfile" targetRef="Task_Sophie_ViewsProfile" />
    <bpmn:sequenceFlow id="Flow_Sophie_ReviewNo" name="No" sourceRef="GW_Sophie_ReviewProfile" targetRef="GW_Sophie_ReviewMerge" />
    <bpmn:sequenceFlow id="Flow_Sophie_5" sourceRef="Task_Sophie_ViewsProfile" targetRef="Task_Sophie_SeesConversations" />
    <bpmn:sequenceFlow id="Flow_Sophie_6" sourceRef="Task_Sophie_SeesConversations" targetRef="Task_Sophie_SeesTestimonials" />
    <bpmn:sequenceFlow id="Flow_Sophie_7" sourceRef="Task_Sophie_SeesTestimonials" targetRef="GW_Sophie_ReviewMerge" />
    <bpmn:sequenceFlow id="Flow_Sophie_ToReturn" sourceRef="GW_Sophie_ReviewMerge" targetRef="Task_Sophie_ReturnsToInvitation" />
    <bpmn:sequenceFlow id="Flow_Sophie_8" sourceRef="Task_Sophie_ReturnsToInvitation" targetRef="GW_Sophie_Accept" />
    <bpmn:sequenceFlow id="Flow_Sophie_NotNow" name="Not now" sourceRef="GW_Sophie_Accept" targetRef="End_Sophie_NotNow" />
    <bpmn:sequenceFlow id="Flow_Sophie_Accept" name="Accept" sourceRef="GW_Sophie_Accept" targetRef="Task_Sophie_Confirms" />
    <bpmn:sequenceFlow id="Flow_Sophie_9" sourceRef="Task_Sophie_Confirms" targetRef="End_Sophie_Confirmed" />
  </bpmn:process>
  <bpmn:process id="Process_System" isExecutable="false">
    <bpmn:startEvent id="Start_System" name="Start">
      <bpmn:outgoing>Flow_Sys_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:task id="Task_Sys_RendersLogin" name="Renders login / handles auth">
      <bpmn:incoming>Flow_Sys_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_2</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_RendersDiscover" name="Renders discover page + map">
      <bpmn:incoming>Flow_Sys_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_3</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_RendersConversation" name="Renders conversation detail with general area">
      <bpmn:incoming>Flow_Sys_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_4</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_AcceptsComment" name="Accepts comment submission">
      <bpmn:incoming>Flow_Sys_4</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_5</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_PresentsInviteFlow" name="Presents invite-to-meet flow">
      <bpmn:incoming>Flow_Sys_5</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_6</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_CreatesPendingInvite" name="Creates pending meeting invitation">
      <bpmn:incoming>Flow_Sys_6</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_7</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_NotifiesSophie" name="Notifies Sophie of invitation">
      <bpmn:incoming>Flow_Sys_7</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_8</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_RendersInviteForSophie" name="Renders invitation detail for Sophie">
      <bpmn:incoming>Flow_Sys_8</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_9</bpmn:outgoing>
    </bpmn:task>
    <bpmn:eventBasedGateway id="GW_Sys_EventBased" name="Awaiting Sophie or cancellation">
      <bpmn:incoming>Flow_Sys_9</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_ToSophieConfirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_Sys_ToTomCancel</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:sequenceFlow id="Flow_Sys_1" sourceRef="Start_System" targetRef="Task_Sys_RendersLogin" />
    <bpmn:sequenceFlow id="Flow_Sys_2" sourceRef="Task_Sys_RendersLogin" targetRef="Task_Sys_RendersDiscover" />
    <bpmn:sequenceFlow id="Flow_Sys_3" sourceRef="Task_Sys_RendersDiscover" targetRef="Task_Sys_RendersConversation" />
    <bpmn:sequenceFlow id="Flow_Sys_4" sourceRef="Task_Sys_RendersConversation" targetRef="Task_Sys_AcceptsComment" />
    <bpmn:sequenceFlow id="Flow_Sys_5" sourceRef="Task_Sys_AcceptsComment" targetRef="Task_Sys_PresentsInviteFlow" />
    <bpmn:sequenceFlow id="Flow_Sys_6" sourceRef="Task_Sys_PresentsInviteFlow" targetRef="Task_Sys_CreatesPendingInvite" />
    <bpmn:sequenceFlow id="Flow_Sys_7" sourceRef="Task_Sys_CreatesPendingInvite" targetRef="Task_Sys_NotifiesSophie" />
    <bpmn:sequenceFlow id="Flow_Sys_8" sourceRef="Task_Sys_NotifiesSophie" targetRef="Task_Sys_RendersInviteForSophie" />
    <bpmn:sequenceFlow id="Flow_Sys_9" sourceRef="Task_Sys_RendersInviteForSophie" targetRef="GW_Sys_EventBased" />
    <bpmn:sequenceFlow id="Flow_Sys_ToSophieConfirm" sourceRef="GW_Sys_EventBased" targetRef="IntCatch_Sys_SophieConfirm" />
    <bpmn:sequenceFlow id="Flow_Sys_ToTomCancel" sourceRef="GW_Sys_EventBased" targetRef="IntCatch_Sys_TomCancels" />
    <bpmn:sequenceFlow id="Flow_Sys_ToCancelTask" sourceRef="IntCatch_Sys_TomCancels" targetRef="Task_Sys_HandlesCancellation" />
    <bpmn:sequenceFlow id="Flow_Sys_10" sourceRef="IntCatch_Sys_SophieConfirm" targetRef="Task_Sys_RevealsLocation" />
    <bpmn:sequenceFlow id="Flow_Sys_11" sourceRef="Task_Sys_RevealsLocation" targetRef="Task_Sys_UpdatesStatus" />
    <bpmn:task id="Task_Sys_RevealsLocation" name="Reveals exact location to both parties">
      <bpmn:incoming>Flow_Sys_10</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_11</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_HandlesCancellation" name="Updates invitation status to cancelled">
      <bpmn:incoming>Flow_Sys_ToCancelTask</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_EndCancel</bpmn:outgoing>
    </bpmn:task>
    <bpmn:endEvent id="End_System_Cancelled" name="End (invitation cancelled)">
      <bpmn:incoming>Flow_Sys_EndCancel</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Sys_EndCancel" sourceRef="Task_Sys_HandlesCancellation" targetRef="End_System_Cancelled" />
    <bpmn:task id="Task_Sys_UpdatesStatus" name="Updates meeting status: pending to scheduled">
      <bpmn:incoming>Flow_Sys_11</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_12</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_Sys_RemovesConversation" name="Removes conversation from discover/map">
      <bpmn:incoming>Flow_Sys_12</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_13</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Sys_12" sourceRef="Task_Sys_UpdatesStatus" targetRef="Task_Sys_RemovesConversation" />
    <bpmn:sequenceFlow id="Flow_Sys_13" sourceRef="Task_Sys_RemovesConversation" targetRef="Task_Sys_NotifiesTom" />
    <bpmn:task id="Task_Sys_NotifiesTom" name="Notifies Tom of confirmation">
      <bpmn:incoming>Flow_Sys_13</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_14</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Sys_14" sourceRef="Task_Sys_NotifiesTom" targetRef="Task_Sys_GeneratesCalendar" />
    <bpmn:endEvent id="End_System" name="End">
      <bpmn:incoming>Flow_Sys_15</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:task id="Task_Sys_GeneratesCalendar" name="Generates calendar event link">
      <bpmn:incoming>Flow_Sys_14</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_15</bpmn:outgoing>
    </bpmn:task>
    <bpmn:sequenceFlow id="Flow_Sys_15" sourceRef="Task_Sys_GeneratesCalendar" targetRef="End_System" />
    <bpmn:intermediateCatchEvent id="IntCatch_Sys_SophieConfirm" name="Receives Sophie&#39;s confirmation">
      <bpmn:incoming>Flow_Sys_ToSophieConfirm</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_10</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_SysConfirm" messageRef="Message_SophieConfirmation" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="IntCatch_Sys_TomCancels" name="Receives Tom&#39;s cancellation">
      <bpmn:incoming>Flow_Sys_ToTomCancel</bpmn:incoming>
      <bpmn:outgoing>Flow_Sys_ToCancelTask</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_SysTomCancel" messageRef="Message_TomCancellation" />
    </bpmn:intermediateCatchEvent>
