    "lilla-watson": {
      "id": "lilla-watson",
      "title": "Lilla Watson",
      "content": {
        "type": "doc",
        "content": [
          {
            "type": "heading",
            "attrs": {
              "level": 1
            },
            "content": [
              {
                "type": "text",
                "text": "Lilla Watson"
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "Lilla Watson is an indigenous Australian artist and activist. She is known for her declaration:"
              }
            ]
          },
          {
            "type": "blockquote",
            "content": [
              {
                "type": "paragraph",
                "content": [
                  {
                    "type": "text",
                    "text": "\"If you have come here to help me, you are wasting your time, but if you have come because your liberation is bound up with mine, then let us work together.\""
                  }
                ]
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "In these paradigms, \"we\" are tightly and inextricably knotted."
              }
            ]
          },
          {
            "type": "paragraph",
            "content": [
              {
                "type": "text",
                "text": "For more on Lilla Watson, see: https://en.wikipedia.org/wiki/Lilla_Watson"
              }
            ]
          }
        ]
      },
      "wikilinks": []
    },
