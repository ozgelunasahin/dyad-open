# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: base URL for page imagery (e.g. /why-page hero images).
# Leave unset to fall back to the default Supabase uploads bucket. Override
# to route static assets through a sovereign host without a code change.
# PUBLIC_ASSET_BASE_URL=https://your-eu-cdn.example/dyad-assets

# Plausible Analytics — privacy-friendly, EU-hosted page-view analytics.
# Set the domain to enable the script tag in the public + authenticated app
# (admin plane is excluded). When unset, no analytics script is loaded.
# PUBLIC_PLAUSIBLE_DOMAIN=dyad.berlin
#
# Optional: override the script URL for self-hosted Plausible deployments.
# Defaults to https://plausible.io/js/script.js when unset.
# PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.dyad.berlin/js/script.js

# Zine storefront — Stripe Payment Links for /zine, one per tier.
# Full-page redirects to Stripe-hosted checkout; no Stripe.js is loaded on
# our pages (see DESIGN.md § Consent-free as a constraint). A tier renders
# only when its URL is set; with none set the page shows "available soon".
# Tier names/descriptions/displayed prices are versioned in
# src/routes/zine/+page.svelte; keep displayed prices in sync with the links.
# PUBLIC_ZINE_PAYMENT_LINK_STANDARD=https://buy.stripe.com/xxxxxxxx
# PUBLIC_ZINE_PAYMENT_LINK_REDUCED=https://buy.stripe.com/yyyyyyyy
# PUBLIC_ZINE_PAYMENT_LINK_SUPPORTER=https://buy.stripe.com/zzzzzzzz

# Email
# EMAIL_PROVIDER selects the adapter under src/lib/server/email-providers/.
# Values: mailpit (default, local dev), resend, migadu.
# EMAIL_PROVIDER=resend
# EMAIL_FROM=hello@dyad.berlin

# Resend (when EMAIL_PROVIDER=resend)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Migadu SMTP (when EMAIL_PROVIDER=migadu). Adapter is currently a stub.
# MIGADU_SMTP_HOST=smtp.migadu.com
# MIGADU_SMTP_USER=hello@dyad.berlin
# MIGADU_SMTP_PASS=

