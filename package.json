{
	"name": "dyad.berlin",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint src/ tests/ --max-warnings 0",
		"precommit": "npm run lint && npm run check && npm run test",
		"premerge": "npm run precommit && npm run test:e2e",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:integration": "vitest run --config vitest.config.integration.ts",
		"pretest:integration": "bash scripts/check-supabase.sh",
		"test:integration:local": "npm run db:env && npm run test:integration",
		"test:db": "npx supabase test db",
		"db:env": "bash scripts/test-env.sh",
		"db:health": "bash scripts/check-supabase.sh",
		"setup": "npx supabase start && npx supabase db reset && npm run db:env",
		"reset": "npx supabase db reset",
		"feedback": "npx tsx scripts/fetch-feedback.ts"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.57.0",
		"@sveltejs/kit": "^2.49.1",
		"@sveltejs/vite-plugin-svelte": "^6.2.1",
		"dotenv": "^17.2.3",
		"eslint": "^10.1.0",
		"eslint-plugin-svelte": "^3.16.0",
		"globals": "^17.4.0",
		"supabase": "^2.72.8",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.2",
		"vite": "^7.2.6",
		"vitest": "^4.0.17"
	},
	"overrides": {
		"@supabase/supabase-js": "$@supabase/supabase-js"
	},
	"dependencies": {
		"@prefig/upact": "file:../prefig/upact",
		"@prefig/upact-supabase": "file:../prefig/upact-supabase",
		"@supabase/ssr": "^0.8.0",
		"@supabase/supabase-js": "^2.90.1",
		"@sveltejs/adapter-cloudflare": "^7.2.5",
		"@tiptap/core": "^3.15.3",
		"@tiptap/extension-image": "^3.15.3",
		"@tiptap/extension-link": "^3.20.5",
		"@tiptap/extension-placeholder": "^3.21.0",
		"@tiptap/html": "^3.18.0",
		"@tiptap/pm": "^3.15.3",
		"@tiptap/starter-kit": "^3.18.0",
		"@types/leaflet": "^1.9.21",
		"@vite-pwa/sveltekit": "^1.1.0",
		"isomorphic-dompurify": "^2.35.0",
		"leaflet": "^1.9.4",
		"nanoid": "^5.1.6"
	}
}
