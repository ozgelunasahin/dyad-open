	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"build:vault": "npx tsx scripts/build-vault.ts",
		"dev": "npm run build:vault && vite dev",
		"build": "npm run build:vault && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
