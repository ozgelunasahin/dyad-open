		"@types/d3-zoom": "^3.0.8",
		"svelte": "^5.45.6",
		"svelte-check": "^4.3.4",
		"typescript": "^5.9.3",
		"vite": "^7.2.6",
		"vitest": "^4.0.17"
	},
	"dependencies": {
		"@vite-pwa/sveltekit": "^1.1.0",
		"d3-selection": "^3.0.0",
		"d3-zoom": "^3.0.0",
		"gray-matter": "^4.0.3",
		"marked": "^17.0.1"
